# Deploy only from your live tree (e.g. Hostinger: ~/laravel_app). Do not mix multiple clones.
APP_NAME="Nexa Technologies"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://retailnexis.com
# Behind proxy / wrong Host header: force public URL (no trailing slash).
APP_PUBLIC_URL=https://retailnexis.com
# SaaS apex domain (subdomains = tenant.retailnexis.com). Must match APP_URL host.
CENTRAL_DOMAIN=retailnexis.com
# Optional: Sanctum SPA domains (comma-separated). Defaults include APP_URL via bootstrap.
# SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,retailnexis.com,www.retailnexis.com

LOG_CHANNEL=stack

# After installer: use saleprosaas_landlord + hPanel MySQL user (never leave Laravel defaults empty on production).
DB_CONNECTION=saleprosaas_landlord
DB_HOST=localhost
DB_PORT=3306
# Landlord (central) database — same MySQL user as tenants on Hostinger.
DB_DATABASE=u123456789_your_landlord_db
DB_USERNAME=u123456789_your_mysql_user
DB_PASSWORD=

# Optional explicit landlord name (defaults to DB_DATABASE when DB_CONNECTION=saleprosaas_landlord). Set if different.
LANDLORD_DB=

# true = production (no "demo disabled" locks). false = legacy demo restrictions. Omit = treated as true.
USER_VERIFIED=true

# --- Stancl tenancy + Hostinger (shared) — one master MySQL user for landlord + all tenants ---
# Prefer DB_HOST=localhost (not 127.0.0.1): Hostinger often grants @'localhost' only; 127.0.0.1 is a different MySQL principal.
SERVER_TYPE=hostinger
# Pre-created tenant DB pool (no CREATE DATABASE at runtime). Defaults to true when SERVER_TYPE=hostinger.
# Set false only if your MySQL user may CREATE DATABASE (e.g. VPS).
# TENANT_DATABASE_POOL_ENABLED=true
# DB_HOST=localhost
# Optional: prefix for tenant DB names (e.g. u123456789_ ) — must match Hostinger DB naming if required.
# DB_PREFIX=
# Pre-created tenant DB names (hPanel). Used by: php artisan tenant:seed-database-pool
# TENANT_DATABASE_POOL_NAMES=u123456789_pool_01,u123456789_pool_02,u123456789_pool_03

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# --- Local dev (XAMPP / artisan serve) ---
# APP_ENV=local
# APP_URL=http://127.0.0.1:8000
# DB_HOST=127.0.0.1
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# --- Post-deploy (SSH in ~/laravel_app) ---
# php artisan saas:hostinger-optimize
# php artisan migrate --path=database/migrations/landlord --force
# php artisan tenants:migrate --force
# php artisan queue:restart
# If routes/views look stale: php artisan optimize:clear && php artisan config:cache
# HTTPS: SESSION_SECURE_COOKIE=true
