APP_NAME="Nexa Technologies"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=https://retailnexis.com
# Behind proxy / wrong Host header: force public URL (no trailing slash).
APP_PUBLIC_URL=https://retailnexis.com
# SaaS apex domain (subdomains = tenant.retailnexis.com). Must match APP_URL host.
CENTRAL_DOMAIN=retailnexis.com
# Optional: Sanctum SPA domains (comma-separated). Defaults include APP_URL via bootstrap.
# SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,retailnexis.com,www.retailnexis.com

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# SaaS landlord DB name (after install: DB_CONNECTION=saleprosaas_landlord). Required for homepage; if missing, same as DB_DATABASE when using landlord connection.
LANDLORD_DB=

# true = production (no "demo disabled" locks). false = legacy demo restrictions. Omit = treated as true.
USER_VERIFIED=true

# --- Stancl tenancy + Hostinger (shared) — one master MySQL user for landlord + all tenants ---
# SERVER_TYPE=hostinger runs CREATE DATABASE via the saleprosaas_tenant connection (same DB_USERNAME/DB_PASSWORD).
# Master user must be allowed to CREATE DATABASE, or create each tenant DB in hPanel and assign this user ALL privileges.
# If you see SQLSTATE 1044 Access denied ... to database — assign DB_USERNAME to that database in hPanel (ALL privileges).
# Prefer DB_HOST=localhost (not 127.0.0.1): Hostinger often grants @'localhost' only; 127.0.0.1 is a different MySQL principal.
SERVER_TYPE=hostinger
# DB_HOST=localhost
# Optional: prefix for tenant DB names (e.g. u123456789_ ) — must match Hostinger DB naming if required.
# DB_PREFIX=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# --- Local dev (override in .env.local only; never commit real .env) ---
# APP_URL=http://127.0.0.1:8000
# APP_PUBLIC_URL=
# CENTRAL_DOMAIN=127.0.0.1
# --- Production (Hostinger / shared hosting) ---
# APP_ENV=production
# APP_DEBUG=false
# DB_HOST=127.0.0.1
# DB_DATABASE=your_hpanel_database
# DB_USERNAME=your_hpanel_mysql_user
# DB_PASSWORD=
