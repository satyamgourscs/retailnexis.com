APP_NAME="Retail Nexis"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com
ASSET_URL=https://yourdomain.com

# Comma-separated hosts for Stancl tenancy (central app). Production: your apex + optional IPs for testing.
# Local dev example: localhost,127.0.0.1,::1
TENANCY_CENTRAL_DOMAINS=yourdomain.com,www.yourdomain.com

# Subdomain parent only (e.g. localhost for satyam.localhost). Must NOT be a tenant hostname (wrong value skips domain sync → 404).
CENTRAL_DOMAIN=yourdomain.com

# false = TenantCreated runs DB create + migrate + finalize in-process (default; no workers). true = async only if QUEUE_CONNECTION is not sync and workers run.
TENANT_QUEUE_PROVISIONING=false

# true = missing tenant DB is created + migrated on first request (fallback after failed provisioning).
TENANT_AUTO_PROVISION_MISSING_DB=true

# Optional: separate public/marketing URL host
# PUBLIC_URL=https://www.yourdomain.com

APP_INSTALLED=true

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=production_db
DB_USERNAME=production_user
DB_PASSWORD=secure_password

LANDLORD_DB=saas_landlord
LANDLORD_DB_CONNECTION=retailnexis_landlord

# Stancl tenant DB template connection (must exist in config/database.php; default local).
TENANT_TEMPLATE_CONNECTION=local

BROADCAST_DRIVER=log
CACHE_DRIVER=database
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Sanctum SPA / cookie auth hosts (comma-separated). Include your production domain and tenant subdomains pattern if needed.
SANCTUM_STATEFUL_DOMAINS=yourdomain.com,www.yourdomain.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

DEBUGBAR_ENABLED=false
